"" Source your .vimrc
"source ~/.vimrc
"Plug 'preservim/nerdtree'
"Plug 'tpope/vim-surround'
"Plug 'terryma/vim-multiple-cursors'
"Plug 'tpope/vim-commentary'
"Plug 'tommcdo/vim-exchange'
"Plug 'machakann/vim-highlightedyank'
"Plug 'vim-matchit'
"Plug 'vim-scripts/argtextobj.vim'
""" Plugins  --------------------------------
set easymotion
set commentary
set exchange
set multiple-cursors
set highlightedyank
set sneak
set matchit
set argtextobj
set NERDTree
set visualbell
set noerrorbells
set which-key

" disable the timeout option
set notimeout

" increase the timeoutlen (default: 1000), don't add space around the equal sign =
set timeoutlen=5000
""" Plugin settings -------------------------
let g:argtextobj_pairs="[:],(:),<:>"
let mapleader=" "
set clipboard+=unnamedplus,unnamed,ideaput
set handler <c-k> a:vim
set handler <c-j> a:vim
"" -- Map IDE actions to IdeaVim -- https://jb.gg/abva4t
""" Idea specific settings ------------------
set ideajoin
"set ideastatusicon=gray
set ideastatusicon=disabled
set idearefactormode=keep

" Find more examples here: https://jb.gg/share-ideavimrc
set ignorecase
set hlsearch
set showmode
set incsearch
set scrolloff=5
set history=1000
set surround
" Do incremental searching.
set relativenumber
set number
set smartcase
set showcmd
""" Mappings --------------------------------
nnoremap <leader>h :nohlsearch<CR>
nnoremap Y y$
vnoremap <leader>p "_dP
" Shorcout for copying to/from System Clipboard
""Copy (Yank)
vmap <leader>y "+y
"" Cute
vmap <leader>d "+d
""Paste
vmap <leader>P "+P
"move visual block
vnoremap <s-Down> :m '>+1<CR>
vnoremap <s-Up> :m '>-2<CR>

nnoremap H ^
nnoremap L g_

vnoremap <C-n> :action SelectNextOccurrence<CR>
vnoremap <C-S-n> :action SelectAllOccurrences<CR>
nnoremap <c-a> gg<S-v>G

"Put search results in the middle of screen
nnoremap n nzz
nnoremap N Nzz

"Some search and replace shorcouts
nnoremap <leader><leader>r :%s//g<Left><Left>
xnoremap <leader><leader>r :s//g<Left><Left>
"open recent project dialog box
nnoremap <leader><leader>m :action ManageRecentProjects<CR>
nmap <leader><leader> <c-^>

nmap <c-e> :NERDTreeToggle<CR>
nmap <leader>sf :NERDTreeFocus<CR>

nnoremap \e :e ~/.ideavimrc<CR>
nnoremap \r :action IdeaVim.ReloadVimRc.reload<CR>

nnoremap <leader>w :w!<CR>

nnoremap ;r :action FindInPath<CR>
nnoremap <Leader>en :action EditSourceInNewWindow<CR>
nnoremap <leader>n :action NextWindow<CR>
nnoremap <leader>q :action CloseEditor<CR>
nnoremap <leader>qa :action CloseAllEditors<CR>

map <C-=> :action EditorSelectWord<CR>

nnoremap <c-z> :action ToggleDistractionFreeMode<CR>
nnoremap <c-t> :action ActivateTerminalToolWindow<CR>
nnoremap <leader>t :action Terminal.OpenInTerminal<CR>
nnoremap <leader>sv :action SplitVertically<CR>
nnoremap <leader>ss :action SplitHorizontally<CR>
nnoremap <leader>us :action Unsplit<CR>
nnoremap <C-S-m> :action MoveEditorToOppositeTabGroup<CR>
nnoremap <C-m> :action MaximizeEditorInSplit<CR>
vnoremap < <gv
vnoremap > >gv
vnoremap = =gv
nnoremap [[ :action MethodUp<CR>
nnoremap ]] :action MethodDown<CR>
nnoremap zc :action CollapseRegion<CR>
nnoremap zo :action ExpandRegion<CR>
nnoremap <leader>zc :action CollapseAllRegions<CR>
nnoremap <leader>zo :action ExpandAllRegions<CR>
nnoremap gc :action CommentByLineComment<CR>
nnoremap gb :action CommentByBlockComment<CR>
nnoremap <leader>k :action QuickJavaDoc<CR>
nnoremap <leader>rt :action Refactorings.QuickListPopupAction<CR>
nnoremap <Leader>rf  :action ReformatCode<CR>
nnoremap <leader>o :action OptimizeImports<CR>
nnoremap ,o :action RecentFiles<CR>
nnoremap \\ :action Switcher<CR>
nnoremap <leader>l :action RecentLocations<CR>
nnoremap <leader>lh  :action LocalHistory.ShowHistory<CR>
nnoremap <leader>r :action RenameElement<CR>
nnoremap <leader>ca :action QuickFixes<CR>
nnoremap <leader>f :action GotoFile<CR>
nnoremap <leader>u :action FindUsages<CR>
nnoremap <leader>s :action GotoRelated<CR>
nnoremap <leader>ch :action CallHierarchy<CR>
nnoremap <leader>b :action ShowNavBar<CR>
nnoremap <c-s> :action FileStructurePopup<CR>
nnoremap ds :action GotoSymbol<CR>
nnoremap <leader>gc :action GotoClass<CR>
nnoremap gi :action GotoImplementation<CR>
nnoremap gd :action GotToDeclaration<CR>
nnoremap <leader>gp :action GotToSuperMethod<CR>
"nnoremap gp :action QuickPreview<CR>
nnoremap <leader>pi :action QuickImplementations<CR>
nnoremap <leader>pd :action QuickTypeDefinition<CR>
nnoremap <leader>gt :action GotoTest<CR>
nnoremap <c-o> :action Back<CR>
nnoremap <c-i> :action Forward<CR>
nnoremap <c-p> :action JumpToLastWindow<CR>
nnoremap <c-x> :action HideAllWindows<CR>


" Debugging
nnoremap ,r :action ContextRun<CR>
nnoremap ,c :action RunClass<CR>
nnoremap ,f :action ChooseRunConfiguration<CR>
nnoremap ,t :action ActivateRunToolWindow<CR>
nnoremap ,u :action Rerun<CR>
nnoremap ,f :action RerunFailedTests<CR>

nnoremap ,b :action ToggleLineBreakpoint<CR>
nnoremap ,d :action ContextDebug<CR>
nnoremap ,n :action ActivateDebugToolWindow<CR>

" Navigation
nnoremap ]e :action GotoNextError<CR>
nnoremap [e :action GotoPreviousError<CR>
nnoremap ]c :action VcsShowNextChangeMarker<CR>
nnoremap [c :action VcsShowPrevChangeMarker<CR>
nnoremap <leader>e :action ShowErrorDescription<CR>
map g; <Action>(JumpToLastChange)
map g, <Action>(JumpToNextChange)

" Scape characters
xmap <leader>sc :action com.materkey.codepoints.ToCodePointsConverter<CR>

" code
nmap <leader>ri :action Inline<CR>
nmap <leader>rev :action IntroduceVariable<CR>
vmap <leader>rev :action IntroduceVariable<CR>
nmap <leader>rem :action ExtractMethod<CR>
vmap <leader>rem :action ExtractMethod<CR>
nmap <leader>rm :action Move<CR>
nmap <leader>rG :action Generate<CR>
