      "    $0",
      "}"
    ],
    "description": "for (Type item : collection)"
  },
  "if not null": {
    "prefix": ["ifnn"],
    "body": [
      "if (${1:obj} != null) {",
      "    $0",
      "}"
    ],
    "description": "if (x != null)"
  },
  "if null": {
    "prefix": ["ifnull"],
    "body": [
      "if (${1:obj} == null) {",
      "    $0",
      "}"
    ],
    "description": "if (x == null)"
  },
  "Optional.ofNullable": {
    "prefix": ["opt"],
    "body": ["Optional.ofNullable(${1:value})$0"],
    "description": "Optional.ofNullable(value)"
  },
  "try-catch": {
    "prefix": ["trycatch", "tc"],
    "body": [
      "try {",
      "    $0",
      "} catch (${1:Exception} ${2:e}) {",
      "    log.error(\"${3:Error: }\", ${2:e});",
      "}"
    ],
    "description": "try { } catch (Exception e)"
  },
