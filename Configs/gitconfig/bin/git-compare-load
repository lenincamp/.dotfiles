#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: git compare-load <branch> [--allow-dirty]

Loads changes from <branch> into your working tree (UNSTAGED), only for files
that differ between HEAD and <branch> (three-dot diff). After that, use
LazyGit/Neovim to stage/discard file by file.

Options:
  --allow-dirty  Skip clean-working-tree safety check
  -h, --help     Show help
EOF
}

ensure_repo() {
  git rev-parse --git-dir >/dev/null 2>&1 || {
    echo "error: not inside a git repository" >&2
    exit 1
  }
}

ensure_branch_exists() {
  local branch="$1"
  git rev-parse --verify --quiet "$branch^{commit}" >/dev/null || {
    echo "error: branch/commit '$branch' not found" >&2
    exit 1
  }
}

ensure_clean_tree() {
  local status
  status="$(git status --porcelain --untracked-files=no)"
  if [[ -n "$status" ]]; then
    echo "error: working tree has local changes (use --allow-dirty if intentional)" >&2
    exit 1
  fi
}

main() {
  ensure_repo

  local allow_dirty=0
  local branch=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --allow-dirty)
        allow_dirty=1
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        if [[ -z "$branch" ]]; then
          branch="$1"
          shift
        else
          echo "error: unexpected argument '$1'" >&2
          usage
          exit 1
        fi
        ;;
    esac
  done

  if [[ -z "$branch" ]]; then
    usage
    exit 1
  fi

  ensure_branch_exists "$branch"
  if [[ $allow_dirty -eq 0 ]]; then
    ensure_clean_tree
  fi

  local -a files=()
  while IFS= read -r -d '' file; do
    files+=("$file")
  done < <(git diff --name-only -z --diff-filter=ACMRTUXB "HEAD...$branch")

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "No differing files between HEAD and $branch"
    exit 0
  fi

  git restore --source "$branch" --worktree -- "${files[@]}"

  echo "Loaded ${#files[@]} file(s) from '$branch' into working tree (unstaged):"
  for f in "${files[@]}"; do
    echo "  - $f"
  done
  echo
  echo "Next: open lazygit and stage/discard per file or hunk."
}

main "$@"
