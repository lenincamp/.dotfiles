[include]
	path = $HOME/.config/bat/themes/catppuccin.gitconfig
[core]
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
	navigate = true  # use n and N to move between diff sections
  ; line-numbers-left-format = ""
  ; line-numbers-right-format = "│ "
[delta "interactive"]
  keep-plus-minus-markers = false
[include]
	# Theme-specific delta colors (auto-generated by nvim colorscheme sync)
	path = ~/.dotfiles/Configs/gitconfig/delta-generated.gitconfig

[pager]
	branch = false
	diff = delta
	log = delta
	reflog = delta
	show = delta
[init]
  defaultBranch = main
[user]
	name = lcampoverde
	email = lenincamp18@gmail.com
[merge]
	tool = nvimdiff
  conflictstyle = merge
[mergetool]
  keepBackup = false
  prompt = false
[mergetool "nvimdiff"]
  cmd = "NVIM_APPNAME=nvim-pure nvim -f -d \"$LOCAL\" \"$MERGED\" \"$REMOTE\""
  trustExitCode = true
[mergetool "nvimdiff-base"]
  cmd = "NVIM_APPNAME=nvim-pure nvim -f -d \"$LOCAL\" \"$BASE\" \"$REMOTE\" \"$MERGED\" -c 'wincmd J'"
  trustExitCode = true
[diff]
  tool = nvimdiff
  colorMoved = default
[difftool]
  prompt = false
  trustExitCode = true
[difftool "nvimdiff"]
  cmd = "NVIM_APPNAME=nvim-pure nvim -f -d \"$LOCAL\" \"$REMOTE\""
[credential]
	helper = osxkeychain
[alias]
  conflict-view = !"$HOME/.dotfiles/Configs/gitconfig/bin/git-conflict-view"
  compare-load = !"$HOME/.dotfiles/Configs/gitconfig/bin/git-compare-load"
