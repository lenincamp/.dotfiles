{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Grep|Glob",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/cbm-code-discovery-gate",
                        "timeout": 5
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "matcher": "startup",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/cbm-session-reminder"
                    }
                ]
            },
            {
                "matcher": "resume",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/cbm-session-reminder"
                    }
                ]
            },
            {
                "matcher": "clear",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/cbm-session-reminder"
                    }
                ]
            },
            {
                "matcher": "compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/cbm-session-reminder"
                    }
                ]
            }
        ]
    }
}
