.DS_Store
**/session/
**/complex_modifications/
settings.local.json
Configs/nvim/.config/nvim/.claude/
Configs/nvim/.config/nvim/.github/
**/nvim.log
Configs/nvim/.config/nvim/lazy-lock.cursor.json
Configs/nvim/.config/nvim/.vscode/settings.json

# agents — project-specific / private (not tracked in dotfiles)
Configs/agents/.agents/projects/
Configs/agents/.agents/skills/patagonia-cdp/
Configs/agents/.agents/.skill-lock.json

# mcp — node_modules excluded, code is tracked
Configs/agents/.agents/mcp/**/node_modules/

# theme-generated files (existing files use --skip-worktree, this prevents new ones)
Configs/iterm2/generated/*.itermcolors
Configs/gitconfig/delta-generated.gitconfig
Configs/gemini/.gemini/settings.json
Configs/lazygit/Library/Application Support/lazygit/config-generated-*.yml
Configs/starship/.config/starship.toml
Configs/nvim/.config/github-copilot/versions.json

# local shell secrets
Configs/zsh/zsh_config/local-secrets.zsh

# system-settings exports (review before committing)
system-settings/defaults/*.plist
